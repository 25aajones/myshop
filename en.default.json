<section class="hero-section">
  <div class="hero-carousel" id="hero-carousel">
    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
        <div class="hero-slide {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <div class="slide-bg">
              {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'slide-img' }}
            </div>
          {% else %}
            <div class="slide-bg slide-bg--gradient" style="--grad: {{ block.settings.gradient_color | default: '#0a0a0a' }}"></div>
          {% endif %}
          <div class="slide-content">
            <p class="slide-eyebrow">{{ block.settings.eyebrow }}</p>
            <h1 class="slide-title">{{ block.settings.title }}</h1>
            <p class="slide-subtitle">{{ block.settings.subtitle }}</p>
            {% if block.settings.cta_label != blank %}
              <a href="{{ block.settings.cta_url }}" class="btn btn--primary">{{ block.settings.cta_label }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% if section.blocks.size > 1 %}
      <div class="carousel-controls">
        <button class="carousel-prev" aria-label="Previous slide">&#8592;</button>
        <div class="carousel-dots">
          {% for block in section.blocks %}
            {% if block.type == 'slide' %}
              <button class="dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
            {% endif %}
          {% endfor %}
        </div>
        <button class="carousel-next" aria-label="Next slide">&#8594;</button>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Carousel",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "color", "id": "gradient_color", "label": "Fallback Color", "default": "#0a0a0a" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "New Release" },
        { "type": "text", "id": "title", "label": "Title", "default": "Ziyu Development" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Apps built with purpose." },
        { "type": "text", "id": "cta_label", "label": "Button Label", "default": "Explore Apps" },
        { "type": "url", "id": "cta_url", "label": "Button URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
