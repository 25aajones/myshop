/* ============================================
   ZIYU DEVELOPMENT — THEME CSS
   Design: Clean tech / editorial / minimal dark
   Fonts: Syne (display) + DM Sans (body)
   ============================================ */

/* --- RESET & BASE --- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --ink:       #0c0c0e;
  --ink-soft:  #1a1a1f;
  --ink-mid:   #2e2e38;
  --mist:      #f5f4f0;
  --mist-dark: #e8e6e0;
  --accent:    #3d5afe;
  --accent-alt:#00bfa5;
  --text:      #111118;
  --text-muted:#6b6b80;
  --white:     #ffffff;
  --radius:    12px;
  --radius-lg: 20px;
  --radius-xl: 32px;
  --transition: 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  --shadow:    0 4px 24px rgba(0,0,0,0.08);
  --shadow-lg: 0 12px 48px rgba(0,0,0,0.14);
  --font-display: 'Syne', sans-serif;
  --font-body:    'DM Sans', sans-serif;
  --nav-height: 68px;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  color: var(--text);
  background: var(--white);
  font-size: 16px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; border: none; background: none; font-family: inherit; }

/* --- TYPOGRAPHY --- */
h1, h2, h3, h4 {
  font-family: var(--font-display);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
}
h1 { font-size: clamp(2.4rem, 6vw, 4.5rem); }
h2 { font-size: clamp(1.8rem, 4vw, 3rem); }
h3 { font-size: clamp(1.2rem, 2.5vw, 1.6rem); }
h4 { font-size: 1.1rem; }

.section-label {
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.75rem;
  display: block;
}

/* --- LAYOUT --- */
.container {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 24px;
}

.section-header {
  margin-bottom: 3rem;
}
.section-header--row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

/* --- BUTTONS --- */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.75rem;
  border-radius: 100px;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 0.92rem;
  letter-spacing: 0.01em;
  transition: all var(--transition);
}
.btn--primary {
  background: var(--accent);
  color: var(--white);
  box-shadow: 0 2px 16px rgba(61,90,254,0.3);
}
.btn--primary:hover {
  background: #2747fa;
  box-shadow: 0 4px 24px rgba(61,90,254,0.45);
  transform: translateY(-1px);
}
.btn--outline {
  border: 1.5px solid var(--ink-mid);
  color: var(--text);
}
.btn--outline:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-1px);
}

/* ============================================
   HEADER
   ============================================ */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0,0,0,0.06);
  transition: box-shadow var(--transition);
}
.site-header.scrolled { box-shadow: var(--shadow); }

.header-inner {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 24px;
  height: var(--nav-height);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.05rem;
  letter-spacing: -0.02em;
}
.logo-mark {
  width: 34px;
  height: 34px;
  background: var(--ink);
  color: var(--white);
  border-radius: 8px;
  display: grid;
  place-items: center;
  font-size: 1.1rem;
  font-weight: 800;
  flex-shrink: 0;
}

.nav-desktop {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}
.nav-link {
  padding: 0.45rem 0.9rem;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-muted);
  transition: all var(--transition);
}
.nav-link:hover, .nav-link.active {
  color: var(--text);
  background: var(--mist);
}
.nav-link.nav-cta {
  background: var(--ink);
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 600;
  margin-left: 0.5rem;
}
.nav-link.nav-cta:hover {
  background: var(--accent);
}

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 8px;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text);
  border-radius: 2px;
  transition: all var(--transition);
}

.nav-mobile {
  display: none;
  flex-direction: column;
  padding: 12px 24px 16px;
  border-top: 1px solid var(--mist-dark);
  gap: 4px;
}
.nav-mobile.open { display: flex; }
.nav-mobile .nav-link { font-size: 1rem; }

/* ============================================
   HERO CAROUSEL
   ============================================ */
.hero-section { overflow: hidden; }

.hero-carousel {
  position: relative;
  min-height: 80vh;
  display: grid;
}

.hero-slide {
  grid-area: 1/1;
  position: relative;
  display: flex;
  align-items: center;
  min-height: 80vh;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.6s ease;
}
.hero-slide.active {
  opacity: 1;
  pointer-events: auto;
}

.slide-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.slide-bg--gradient {
  background: linear-gradient(135deg, var(--grad, #0a0a0a) 0%, #1a1a2e 100%);
}
.slide-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.slide-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.1));
}

.slide-content {
  position: relative;
  z-index: 2;
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 24px;
  width: 100%;
  color: var(--white);
}
.slide-eyebrow {
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 1rem;
}
.slide-title {
  margin-bottom: 1rem;
  max-width: 700px;
  font-size: clamp(3rem, 7vw, 5.5rem);
}
.slide-subtitle {
  font-size: 1.15rem;
  color: rgba(255,255,255,0.75);
  max-width: 500px;
  margin-bottom: 2rem;
}

.carousel-controls {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 1rem;
  z-index: 10;
}
.carousel-prev, .carousel-next {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  color: white;
  font-size: 1.1rem;
  display: grid;
  place-items: center;
  transition: background var(--transition);
  backdrop-filter: blur(6px);
}
.carousel-prev:hover, .carousel-next:hover { background: rgba(255,255,255,0.3); }

.carousel-dots { display: flex; gap: 6px; }
.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  transition: all var(--transition);
}
.dot.active {
  background: white;
  width: 22px;
  border-radius: 4px;
}

/* ============================================
   ABOUT STRIP
   ============================================ */
.about-strip {
  padding: 6rem 0;
  background: var(--ink);
  color: var(--white);
}
.about-strip .section-label { color: var(--accent-alt); }

.about-strip__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.about-strip__text h2 { color: var(--white); margin-bottom: 1rem; }
.about-body { color: rgba(255,255,255,0.65); margin-bottom: 2rem; max-width: 420px; }

.about-strip__goals { padding-top: 2.5rem; }
.about-strip__goals .section-label { color: rgba(255,255,255,0.4); }

.goal-item {
  display: flex;
  gap: 1.25rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.goal-item:last-child { border-bottom: none; }
.goal-num {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent);
  padding-top: 3px;
  flex-shrink: 0;
}
.goal-item h4 { color: var(--white); margin-bottom: 0.25rem; }
.goal-item p { color: rgba(255,255,255,0.5); font-size: 0.9rem; }

/* ============================================
   APPS SECTION
   ============================================ */
.apps-section {
  padding: 6rem 0;
  background: var(--mist);
}

.apps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}

.app-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  gap: 1.25rem;
  align-items: flex-start;
  border: 1px solid rgba(0,0,0,0.05);
  transition: all var(--transition);
  box-shadow: var(--shadow);
}
.app-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(61,90,254,0.2);
}

.app-card__icon {
  width: 64px;
  height: 64px;
  border-radius: 14px;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--mist);
}
.app-card__icon img { width: 100%; height: 100%; object-fit: cover; }

.app-icon-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--ink) 0%, var(--ink-mid) 100%);
  color: white;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.5rem;
  display: grid;
  place-items: center;
  border-radius: 14px;
}

.app-card__info h3 { font-size: 1rem; margin-bottom: 0.35rem; }
.app-card__info p { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.75rem; }

.app-store-badge {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.02em;
}

.coming-soon-strip {
  margin-top: 3rem;
  padding-top: 3rem;
  border-top: 1px solid var(--mist-dark);
}
.coming-soon-grid {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-top: 1rem;
}
.coming-soon-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  text-align: center;
}
.coming-soon-icon {
  width: 60px;
  height: 60px;
  opacity: 0.4;
  font-size: 1.2rem;
}
.coming-soon-card span { font-size: 0.85rem; font-weight: 500; }
.coming-soon-card em { font-size: 0.72rem; color: var(--text-muted); font-style: normal; }

/* ============================================
   BLOG PREVIEW / LISTING
   ============================================ */
.blog-preview {
  padding: 6rem 0;
}
.blog-listing {
  padding: 4rem 0 6rem;
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 2rem;
}
.blog-grid--full { grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); }

.blog-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--mist-dark);
  transition: all var(--transition);
  background: var(--white);
  display: flex;
  flex-direction: column;
}
.blog-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(61,90,254,0.2);
}

.blog-card__img {
  height: 200px;
  overflow: hidden;
  background: var(--mist);
}
.blog-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
.blog-card:hover .blog-card__img img { transform: scale(1.04); }
.blog-card__img--placeholder {
  background: linear-gradient(135deg, var(--ink) 0%, #2a2a4a 100%);
}

.blog-card__body {
  padding: 1.5rem;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.blog-tag {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.6rem;
  display: block;
}
.blog-card__body h2, .blog-card__body h3 { margin-bottom: 0.5rem; font-size: 1.15rem; }
.blog-card__body p { color: var(--text-muted); font-size: 0.9rem; flex: 1; }
.blog-card__body time {
  display: block;
  margin-top: 1rem;
  font-size: 0.8rem;
  color: var(--text-muted);
}

.blog-filters {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.filter-btn {
  padding: 0.45rem 1.1rem;
  border-radius: 100px;
  border: 1.5px solid var(--mist-dark);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-muted);
  transition: all var(--transition);
}
.filter-btn:hover, .filter-btn.active {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(61,90,254,0.06);
}

/* ============================================
   ARTICLE PAGE
   ============================================ */
.article-hero {
  position: relative;
  background: var(--ink);
  color: var(--white);
  overflow: hidden;
}
.article-hero__img {
  height: 420px;
  overflow: hidden;
}
.article-hero__img img { width: 100%; height: 100%; object-fit: cover; opacity: 0.45; }

.article-hero__content {
  padding: 3rem 0;
}
.article-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.back-link {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
  transition: color var(--transition);
}
.back-link:hover { color: var(--white); }

.article-hero h1 { color: var(--white); margin-bottom: 1rem; }
.article-byline {
  display: flex;
  gap: 1.5rem;
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
}

.article-body {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 4rem;
  padding: 4rem 24px;
  align-items: start;
}

.article-content.rte {
  font-size: 1.05rem;
  line-height: 1.8;
}
.rte h2 { margin: 2rem 0 1rem; }
.rte h3 { margin: 1.5rem 0 0.75rem; }
.rte p { margin-bottom: 1.25rem; color: #2c2c3a; }
.rte ul, .rte ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
.rte li { margin-bottom: 0.4rem; }
.rte img { border-radius: var(--radius); margin: 2rem 0; }

.article-sidebar { position: sticky; top: calc(var(--nav-height) + 2rem); }
.sidebar-widget h4 {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}
.sidebar-post {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 0.75rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--mist-dark);
  font-size: 0.85rem;
}
.sidebar-post:hover { color: var(--accent); }
.sidebar-post time { font-size: 0.75rem; color: var(--text-muted); flex-shrink: 0; }

.article-footer { padding-bottom: 4rem; }

/* ============================================
   PRODUCTS PAGE
   ============================================ */
.products-page { padding: 4rem 24px 6rem; }
.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1.5rem;
}

.product-card {
  border-radius: var(--radius-lg);
  background: var(--white);
  border: 1px solid var(--mist-dark);
  padding: 1.75rem;
  text-align: center;
  transition: all var(--transition);
  box-shadow: var(--shadow);
}
.product-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(61,90,254,0.25);
}
.product-card__icon {
  width: 90px;
  height: 90px;
  border-radius: 20px;
  overflow: hidden;
  margin: 0 auto 1.25rem;
  background: var(--mist);
}
.product-card__icon img { width: 100%; height: 100%; object-fit: cover; }
.product-card__info h3 { font-size: 1rem; margin-bottom: 0.4rem; }
.product-card__info p { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.75rem; }

/* ============================================
   PRODUCT DETAIL
   ============================================ */
.product-page {
  padding: 3rem 24px 6rem;
}
.product-detail {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  margin-top: 2rem;
  align-items: start;
}
.product-icon-large {
  width: 160px;
  height: 160px;
  border-radius: 36px;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  margin-bottom: 2rem;
}
.product-icon-large img { width: 100%; height: 100%; object-fit: cover; }

.product-screenshots {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.screenshot {
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  width: 100%;
}
.product-tagline {
  font-size: 1.15rem;
  color: var(--text-muted);
  margin: 0.75rem 0 2rem;
}
.product-description { margin-bottom: 2rem; }
.coming-soon-badge {
  display: inline-flex;
  padding: 0.5rem 1.25rem;
  background: var(--mist);
  border-radius: 100px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

/* ============================================
   PAGE HERO
   ============================================ */
.page-hero {
  background: var(--ink);
  color: var(--white);
  padding: 5rem 0;
}
.page-hero--blog { padding: 4rem 0; }
.page-hero--about {
  background: linear-gradient(135deg, var(--ink) 0%, #1a1a3e 100%);
}
.page-hero h1 { color: var(--white); margin-bottom: 0.5rem; }
.page-hero__desc {
  color: rgba(255,255,255,0.6);
  font-size: 1.1rem;
  max-width: 500px;
  margin-top: 1rem;
}

/* ============================================
   ABOUT PAGE
   ============================================ */
.about-page { padding: 5rem 24px 6rem; }
.about-intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  margin-bottom: 5rem;
}
.about-intro__text.rte h2 { margin-bottom: 1rem; }
.about-intro__visual { position: relative; height: 300px; }
.about-blob {
  width: 260px;
  height: 260px;
  border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-alt) 100%);
  opacity: 0.15;
  animation: blob 8s ease-in-out infinite;
}
@keyframes blob {
  0%, 100% { border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%; }
  50% { border-radius: 30% 70% 40% 60% / 60% 40% 50% 40%; }
}

.team-section { margin-top: 3rem; }
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 2rem;
  margin-top: 1.5rem;
}
.team-card { text-align: center; }
.team-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: var(--mist);
  margin: 0 auto 1rem;
}
.team-card--placeholder .team-avatar { opacity: 0.4; }
.team-card h4 { font-size: 1rem; }
.team-card p { font-size: 0.85rem; color: var(--text-muted); }

/* ============================================
   CONTACT PAGE
   ============================================ */
.contact-page { padding: 5rem 24px 6rem; }
.contact-layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
}
.contact-info h3 { margin-bottom: 1rem; }
.contact-info p { color: var(--text-muted); margin-bottom: 1.5rem; }
.contact-email {
  font-family: var(--font-display);
  font-weight: 600;
  color: var(--accent);
  font-size: 0.95rem;
}

.form-field {
  margin-bottom: 1.5rem;
}
.form-field label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--text-muted);
}
.form-field input, .form-field textarea {
  width: 100%;
  padding: 0.85rem 1.1rem;
  border: 1.5px solid var(--mist-dark);
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--text);
  background: var(--white);
  transition: border-color var(--transition);
  resize: vertical;
}
.form-field input:focus, .form-field textarea:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(61,90,254,0.1);
}

.form-success {
  background: rgba(0,191,165,0.1);
  border: 1px solid var(--accent-alt);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  margin-bottom: 1.5rem;
  color: var(--accent-alt);
  font-weight: 500;
}
.form-errors {
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.3);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  margin-bottom: 1.5rem;
  color: #dc2626;
  font-size: 0.9rem;
}

/* ============================================
   FOOTER
   ============================================ */
.site-footer {
  background: var(--ink);
  color: rgba(255,255,255,0.55);
  padding: 5rem 0 0;
}
.footer-inner {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: start;
  padding-bottom: 4rem;
}
.site-footer .logo-mark { background: rgba(255,255,255,0.1); }
.site-footer .logo-text { color: rgba(255,255,255,0.85); }
.footer-tagline { font-size: 0.9rem; margin-top: 0.75rem; }
.footer-links { display: flex; gap: 4rem; }
.footer-col { display: flex; flex-direction: column; gap: 0.75rem; }
.footer-col h4 {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin-bottom: 0.25rem;
}
.footer-col a { font-size: 0.9rem; transition: color var(--transition); }
.footer-col a:hover { color: rgba(255,255,255,0.9); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.07);
  padding: 1.5rem 24px;
  max-width: 1160px;
  margin: 0 auto;
  font-size: 0.8rem;
}

/* ============================================
   404 PAGE
   ============================================ */
.error-page {
  padding: 8rem 24px;
  text-align: center;
}
.error-code {
  font-family: var(--font-display);
  font-size: 8rem;
  font-weight: 800;
  color: var(--mist-dark);
  line-height: 1;
  margin-bottom: 1rem;
}
.error-content h1 { margin-bottom: 1rem; }
.error-content p { color: var(--text-muted); margin-bottom: 2rem; }

/* ============================================
   UTILITIES
   ============================================ */
.empty-state {
  color: var(--text-muted);
  font-style: italic;
  padding: 3rem 0;
}
.pagination {
  margin-top: 4rem;
  display: flex;
  justify-content: center;
  gap: 0.5rem;
}

/* Page content generic */
.page-content {
  padding: 5rem 24px 6rem;
}
.page-content .rte { max-width: 720px; }

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 900px) {
  .about-strip__inner { grid-template-columns: 1fr; gap: 3rem; }
  .product-detail { grid-template-columns: 1fr; gap: 3rem; }
  .article-body { grid-template-columns: 1fr; }
  .article-sidebar { display: none; }
  .about-intro { grid-template-columns: 1fr; }
  .about-intro__visual { display: none; }
  .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
  .footer-inner { grid-template-columns: 1fr; gap: 3rem; }
}

@media (max-width: 768px) {
  .nav-desktop { display: none; }
  .nav-toggle { display: flex; }
  .hero-slide { min-height: 65vh; }
  .slide-bg::after {
    background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.7));
  }
  .blog-grid { grid-template-columns: 1fr; }
  .apps-grid { grid-template-columns: 1fr; }
  .products-grid { grid-template-columns: repeat(2, 1fr); }
  .footer-links { flex-direction: column; gap: 2rem; }
}

@media (max-width: 480px) {
  .products-grid { grid-template-columns: 1fr; }
  h1 { font-size: 2.2rem; }
  .slide-title { font-size: 2.5rem; }
}

/* ============================================
   ANIMATIONS / TRANSITIONS
   ============================================ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-slide.active .slide-eyebrow { animation: fadeUp 0.5s ease 0.1s both; }
.hero-slide.active .slide-title   { animation: fadeUp 0.5s ease 0.2s both; }
.hero-slide.active .slide-subtitle{ animation: fadeUp 0.5s ease 0.3s both; }
.hero-slide.active .btn           { animation: fadeUp 0.5s ease 0.4s both; }
