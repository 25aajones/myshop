<section class="blog-preview">
  <div class="container">
    <div class="section-header section-header--row">
      <div>
        <p class="section-label">Blog</p>
        <h2>Recently Updated</h2>
      </div>
      <a href="/blogs/news" class="btn btn--outline">More Posts →</a>
    </div>

    <div class="blog-grid">
      {% assign blog = blogs[section.settings.blog] %}
      {% if blog != blank %}
        {% for article in blog.articles limit: section.settings.limit %}
          <a href="{{ article.url }}" class="blog-card">
            {% if article.image %}
              <div class="blog-card__img">
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
              </div>
            {% else %}
              <div class="blog-card__img blog-card__img--placeholder"></div>
            {% endif %}
            <div class="blog-card__body">
              <span class="blog-tag">{{ article.tags | first | default: 'Update' }}</span>
              <h3>{{ article.title }}</h3>
              <p>{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
              <time>{{ article.published_at | date: '%b %d, %Y' }}</time>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="blog-card blog-card--placeholder">
          <div class="blog-card__img blog-card__img--placeholder"></div>
          <div class="blog-card__body">
            <span class="blog-tag">Update</span>
            <h3>First Post Coming Soon</h3>
            <p>Stay tuned for updates, release notes, and development insights.</p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Preview",
  "settings": [
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "limit", "label": "Number of Posts", "min": 1, "max": 6, "step": 1, "default": 3 }
  ],
  "presets": [
    { "name": "Blog Preview" }
  ]
}
{% endschema %}
