<aside class="zy-updates">
  <h3>Updates to Apps</h3>
  {% assign updates_blog = blogs['updates'] %}
  {% if updates_blog and updates_blog.articles_count > 0 %}
    <ul class="zy-updates-list">
      {% for article in updates_blog.articles limit: 5 %}
        <li>
          <strong>{{ article.title }}</strong>
          <span class="zy-updates-date">{{ article.published_at | date: "%b %d" }}</span>
          <p>{{ article.excerpt | strip_html | truncate: 90 }}</p>
        </li>
      {% endfor %}
    </ul>
    <a href="{{ updates_blog.url }}" class="zy-link">View all release notes →</a>
  {% else %}
    <p>No updates yet. Create an "updates" blog for release notes.</p>
  {% endif %}

  <div class="zy-weekly-seeds">
    <h4>Weekly Seeds</h4>
    <p>Short, focused tips on engineering, architecture, and sustainable development.</p>
    <form action="/contact#weekly-seeds" method="post">
      <input type="email" name="contact[email]" placeholder="Email address" required>
      <button type="submit">Get the newsletter</button>
    </form>
  </div>
</aside>
