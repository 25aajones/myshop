<section class="section newsletter-section">
  <div class="container newsletter-card">
    <div class="section-title">
      <h2>{{ section.settings.heading | default: 'Stay Updated' }}</h2>
      <p>{{ section.settings.subheading | default: 'Get updates on new apps, products, launches, and exclusive drops.' }}</p>
    </div>

    {% form 'customer' %}
      <div class="newsletter-form">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.email_placeholder | default: 'Enter your email' }}"
        >

        <button type="submit" class="btn btn-primary">
          {{ section.settings.button_label | default: 'Subscribe' }}
        </button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay Updated"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get updates on new apps, products, launches, and exclusive drops."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
