<section class="section featured-products">
  <div class="container">
    <div class="section-title">
      <h2>{{ section.settings.heading | default: 'Trending Products' }}</h2>
      <p>{{ section.settings.subheading | default: 'Popular tech, tools, and merch from Ziyu Development.' }}</p>
    </div>

    <div class="grid">
      {% assign featured_collection = collections[section.settings.collection] %}
      {% assign products = featured_collection != blank ? featured_collection.products : collections.all.products %}
      {% for product in products limit: section.settings.product_limit %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Products"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Popular tech, tools, and merch from Ziyu Development."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured collection",
      "default": "all"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Product limit",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
