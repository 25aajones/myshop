<section class="zy-section">
  <div class="zy-section-header">
    <h2>Recent Insights</h2>
    <p>Engineering notes on sustainable development, performance, and calm interfaces.</p>
  </div>
  <div class="zy-posts-grid">
    {% assign featured_blog = blogs['news'] %}
    {% if featured_blog and featured_blog.articles_count > 0 %}
      {% for article in featured_blog.articles limit: 3 %}
        <article class="zy-post-card">
          <p class="zy-post-meta">{{ article.published_at | date: "%B %d, %Y" }}</p>
          <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
          <p>{{ article.excerpt | strip_html | truncate: 140 }}</p>
          <a href="{{ article.url }}" class="zy-link">Read article →</a>
        </article>
      {% endfor %}
    {% else %}
      <p>No posts yet. Create some articles in your "news" blog.</p>
    {% endif %}
  </div>
</section>
