<div id="zy-cart-drawer" class="zy-cart-drawer">
  <div class="zy-cart-drawer-backdrop"></div>
  <div class="zy-cart-drawer-panel">
    <header class="zy-cart-drawer-header">
      <h2>Your Cart</h2>
      <button type="button" class="zy-cart-drawer-close" aria-label="Close cart">×</button>
    </header>
    <div class="zy-cart-drawer-body">
      {% if cart.item_count > 0 %}
        <ul class="zy-cart-items">
          {% for item in cart.items %}
            <li class="zy-cart-item">
              <div>
                <p class="zy-cart-item-title">{{ item.product.title }}</p>
                <p class="zy-cart-item-meta">Qty {{ item.quantity }} · {{ item.line_price | money }}</p>
              </div>
            </li>
          {% endfor %}
        </ul>
        <div class="zy-cart-summary">
          <p>Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
          <a href="/cart" class="zy-btn zy-btn-primary zy-full-width">View cart</a>
          <a href="/checkout" class="zy-btn zy-btn-ghost zy-full-width">Checkout</a>
        </div>
      {% else %}
        <p>Your cart is empty.</p>
      {% endif %}
    </div>
  </div>
</div>
