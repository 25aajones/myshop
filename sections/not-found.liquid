<section class="section not-found-page reveal-on-scroll">
  <div class="container not-found-card">
    <div class="section-title">
      <h1>{{ section.settings.heading | default: 'Page not found' }}</h1>
      <p>{{ section.settings.subheading | default: 'Sorry, the page you are looking for may have been removed or the URL is incorrect.' }}</p>
    </div>

    <div class="not-found-actions">
      <a href="/" class="btn btn-primary">{{ section.settings.primary_button_label | default: 'Return home' }}</a>
      <a href="/collections/all" class="btn btn-secondary">{{ section.settings.secondary_button_label | default: 'Browse products' }}</a>
    </div>

    <form action="/search" method="get" class="search-form">
      <input type="search" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Search products, collections, and more' }}" aria-label="Search site">
      <button type="submit" class="btn btn-primary">{{ section.settings.search_button_label | default: 'Search' }}</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sorry, the page you are looking for may have been removed or the URL is incorrect."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Return home"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Browse products"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search products, collections, and more"
    },
    {
      "type": "text",
      "id": "search_button_label",
      "label": "Search button label",
      "default": "Search"
    }
  ],
  "presets": [
    {
      "name": "404 page"
    }
  ]
}
{% endschema %}
