<section class="zy-section">
  <div class="zy-section-header">
    <h2>Apps in the Garden</h2>
    <p>Curated tools designed for deep focus and long-term growth.</p>
  </div>
  <div class="zy-product-grid">
    {% for product in collection.products %}
      {% assign is_app = product.metafields.app.is_app %}
      {% assign app_store_url = product.metafields.app.app_store_url %}
      {% assign play_store_url = product.metafields.app.play_store_url %}

      <article class="zy-product-card">
        <a href="{{ product.url }}" class="zy-product-media">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '540x' }}" alt="{{ product.title }}">
          {% endif %}
        </a>
        <div class="zy-product-body">
          <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <p class="zy-product-price">{{ product.price | money }}</p>
          {% if product.description != blank %}
            <p class="zy-product-excerpt">{{ product.description | strip_html | truncate: 110 }}</p>
          {% endif %}

          {% if is_app %}
            <div class="zy-app-buttons">
              {% if app_store_url %}
                <a href="{{ app_store_url }}" class="zy-btn zy-btn-primary zy-full-width" target="_blank" rel="noopener">View on App Store</a>
              {% endif %}
              {% if play_store_url %}
                <a href="{{ play_store_url }}" class="zy-btn zy-btn-ghost zy-full-width" target="_blank" rel="noopener">View on Google Play</a>
              {% endif %}
            </div>
          {% else %}
            <form method="post" action="/cart/add" class="zy-add-to-cart">
              <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
              <button type="submit">Add to cart</button>
            </form>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>
