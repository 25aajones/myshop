<section class="section testimonials reveal-on-scroll">
  <div class="container">
    <div class="section-title">
      <h2>{{ section.settings.heading | default: 'Trusted by ambitious teams' }}</h2>
      <p>{{ section.settings.subheading | default: 'Use testimonials, reviews, and social proof to build momentum around launches and paid campaigns.' }}</p>
    </div>

    <div class="testimonial-grid">
      {% for block in section.blocks %}
        <article class="testimonial-card">
          <p>{{ block.settings.quote }}</p>
          <footer>
            <div>
              <p class="testimonial-name">{{ block.settings.name }}</p>
              <p class="testimonial-role">{{ block.settings.role }}</p>
            </div>
          </footer>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by ambitious teams"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use testimonials, reviews, and social proof to build momentum around launches and paid campaigns."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This theme helped our team launch faster and convert more customers."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Ava Johnson"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Founder, Loop Labs"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
