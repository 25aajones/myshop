<section class="section promo-banner reveal-on-scroll">
  <div class="container promo-card">
    <div class="promo-copy">
      <p class="eyebrow">{{ section.settings.tagline | default: 'Limited time offer' }}</p>
      <h2>{{ section.settings.heading | default: 'Launch the next version of your store' }}</h2>
      <p>{{ section.settings.subheading | default: 'Use this marketing-ready section to promote a new product drop, sale event, or launch campaign directly from the theme editor.' }}</p>
      <div class="button-group promo-actions">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn-primary">
          {{ section.settings.button_label | default: 'Get started' }}
        </a>
      </div>
      {% if section.settings.small_text != blank %}
        <p class="promo-note">{{ section.settings.small_text }}</p>
      {% endif %}
    </div>

    {% if section.settings.countdown_date != blank %}
      <div class="promo-countdown" data-countdown="{{ section.settings.countdown_date }}">
        <p class="eyebrow countdown-message">{{ section.settings.countdown_intro | default: 'Sale ends in' }}</p>
        <div class="countdown-grid">
          <div class="countdown-number">
            <strong data-countdown-days>0</strong>
            Days
          </div>
          <div class="countdown-number">
            <strong data-countdown-hours>0</strong>
            Hours
          </div>
          <div class="countdown-number">
            <strong data-countdown-minutes>0</strong>
            Minutes
          </div>
          <div class="countdown-number">
            <strong data-countdown-seconds>0</strong>
            Seconds
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Promo banner",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Limited time offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch the next version of your store"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use this marketing-ready section to promote a new product drop, sale event, or launch campaign directly from the theme editor."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get started"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "small_text",
      "label": "Small supporting text",
      "default": "Create urgency with a limited-time promotion, launch countdown, or early access offer."
    },
    {
      "type": "text",
      "id": "countdown_intro",
      "label": "Countdown intro text",
      "default": "Sale ends in"
    },
    {
      "type": "text",
      "id": "countdown_date",
      "label": "Countdown target date",
      "default": "2026-12-31"
    }
  ],
  "presets": [
    {
      "name": "Promo banner"
    }
  ]
}
{% endschema %}
