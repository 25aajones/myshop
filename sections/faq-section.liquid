<section class="section faq-section reveal-on-scroll">
  <div class="container">
    <div class="section-title">
      <h2>{{ section.settings.heading | default: 'Frequently asked questions' }}</h2>
      <p>{{ section.settings.subheading | default: 'Answer common questions, reduce friction, and support your campaigns with clear, editable FAQ content.' }}</p>
    </div>

    <div class="faq-list">
      {% for block in section.blocks %}
        <details class="faq-item"{% if block.settings.open %} open{% endif %}>
          <summary>{{ block.settings.question }}</summary>
          <div class="faq-answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Answer common questions, reduce friction, and support your campaigns with clear, editable FAQ content."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "We offer a 30-day return policy for most products. Contact support for details."
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "FAQ section"
    }
  ]
}
{% endschema %}
