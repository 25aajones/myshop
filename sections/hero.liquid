{% if section.settings.hero_image != blank %}
<section class="hero" style="background-image: linear-gradient(rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.6 }}), rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.6 }})), url('{{ section.settings.hero_image | image_url: width: 2000 }}');">
{% else %}
<section class="hero">
{% endif %}
  <div class="hero-content container">
    {% if section.settings.preheading != blank %}
      <p class="eyebrow">{{ section.settings.preheading }}</p>
    {% endif %}

    <h1>{{ section.settings.heading | default: 'Build Better. Upgrade Everything.' }}</h1>

    <p>{{ section.settings.subheading | default: 'Apps, tech gear, print-on-demand merch, and digital tools designed by Ziyu Development.' }}</p>

    <div class="button-group">
      {% if section.settings.primary_button_label != blank %}
        <a href="{{ section.settings.primary_button_url | default: '/collections/all' }}" class="btn btn-primary">
          {{ section.settings.primary_button_label }}
        </a>
      {% endif %}

      {% if section.settings.secondary_button_label != blank %}
        <a href="{{ section.settings.secondary_button_url | default: '/pages/about' }}" class="btn btn-secondary">
          {{ section.settings.secondary_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.65
    },
    {
      "type": "text",
      "id": "preheading",
      "label": "Preheading text",
      "default": "Tech-garden philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Garden Your Goals"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We engineer high-precision software designed to nurture your personal and professional growth. Experience the synthesis of digital efficiency and organic evolution."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Explore Our Apps"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Primary button URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary button URL",
      "default": "/pages/about"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
