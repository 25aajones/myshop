<section class="section about-preview">
  <div class="container about-grid">
    <div class="about-copy">
      <div class="section-title">
        <h2>{{ section.settings.heading | default: 'Why Ziyu Development?' }}</h2>
      </div>
      <p>{{ section.settings.text | default: 'Ziyu Development combines technology, creativity, and modern design into products that help people create, learn, and improve.' }}</p>
      <a href="{{ section.settings.button_url | default: '/pages/about' }}" class="btn btn-primary">
        {{ section.settings.button_label | default: 'Learn More' }}
      </a>
    </div>

    {% if section.settings.image != blank %}
      <div class="about-image">
        <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.heading }}">
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "About preview",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Ziyu Development?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Ziyu Development combines technology, creativity, and modern design into products that help people create, learn, and improve."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "default": "/pages/about"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side image"
    }
  ],
  "presets": [
    {
      "name": "About preview"
    }
  ]
}
{% endschema %}
