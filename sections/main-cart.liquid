<section class="section cart-page reveal-on-scroll">
  <div class="container cart-card">
    <div class="section-title">
      <h1>{{ section.settings.heading | default: 'Your cart' }}</h1>
    </div>

    {% if cart.item_count > 0 %}
      <div class="cart-table-wrapper">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                  {% if item.variant.title != 'Default Title' %}
                    <p>{{ item.variant.title }}</p>
                  {% endif %}
                </td>
                <td>{{ item.price | money }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="cart-summary">
        <p class="cart-total-label">Subtotal</p>
        <p class="cart-total-price">{{ cart.total_price | money }}</p>
        <div class="button-group">
          <a href="/checkout" class="btn btn-primary">Checkout</a>
        </div>
      </div>
    {% else %}
      <div class="empty-state">
        <p>Your cart is currently empty.</p>
        <a href="/collections/all" class="btn btn-secondary">Continue shopping</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart"
    }
  ],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}
