<section class="zy-page">
  <h1 class="zy-page-title">Release Notes</h1>
  <p class="zy-page-subtitle">Changelogs and updates across all apps in the garden.</p>

  {% assign updates_blog = blogs['updates'] %}
  {% if updates_blog %}
    {% paginate updates_blog.articles by 10 %}
      <ul class="zy-updates-list zy-updates-list--page">
        {% for article in updates_blog.articles %}
          <li>
            <strong>{{ article.title }}</strong>
            <span class="zy-updates-date">{{ article.published_at | date: "%B %d, %Y" }}</span>
            <p>{{ article.excerpt | strip_html | truncate: 160 }}</p>
            <a href="{{ article.url }}" class="zy-link">View details →</a>
          </li>
        {% endfor %}
      </ul>
      {{ paginate | default_pagination }}
    {% endpaginate %}
  {% else %}
    <p>Create an "updates" blog to power this page.</p>
  {% endif %}
</section>
