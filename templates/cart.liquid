<section class="zy-page">
  <h1 class="zy-page-title">Your Cart</h1>

  {% if cart.item_count == 0 %}
    <p>Your cart is empty. Explore the <a href="/collections/all">app collection</a>.</p>
  {% else %}
    <table class="zy-cart-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Qty</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        {% for item in cart.items %}
          <tr>
            <td>{{ item.product.title }}</td>
            <td>{{ item.quantity }}</td>
            <td>{{ item.line_price | money }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <div class="zy-cart-summary zy-cart-summary--page">
      <p>Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
      <a href="/checkout" class="zy-btn zy-btn-primary">Checkout</a>
    </div>
  {% endif %}
</section>
