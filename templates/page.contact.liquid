<section class="zy-page">
  <h1 class="zy-page-title">Contact Us</h1>
  <p class="zy-page-subtitle">Reach out about app support, collaborations, or custom builds.</p>

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <p class="zy-form-success">Thanks for reaching out. We'll get back to you soon.</p>
    {% endif %}

    <div class="zy-form-grid">
      <input type="text" name="contact[name]" placeholder="Your name" required>
      <input type="email" name="contact[email]" placeholder="Your email" required>
    </div>
    <textarea name="contact[body]" rows="6" placeholder="How can we help?" required></textarea>
    <button type="submit" class="zy-btn zy-btn-primary">Send message</button>
  {% endform %}
</section>
