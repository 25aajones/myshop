<div class="page-hero page-hero--blog">
  <div class="container">
    <p class="section-label">Ziyu Development</p>
    <h1>{{ blog.title }}</h1>
  </div>
</div>

<div class="container blog-listing">
  <div class="blog-filters">
    <button class="filter-btn active" data-tag="all">All</button>
    <button class="filter-btn" data-tag="update">Updates</button>
    <button class="filter-btn" data-tag="release">Releases</button>
    <button class="filter-btn" data-tag="apps">Apps</button>
  </div>

  <div class="blog-grid blog-grid--full">
    {% for article in blog.articles %}
      <a href="{{ article.url }}" class="blog-card" data-tags="{{ article.tags | join: ',' | downcase }}">
        {% if article.image %}
          <div class="blog-card__img">
            {{ article.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: article.title }}
          </div>
        {% else %}
          <div class="blog-card__img blog-card__img--placeholder"></div>
        {% endif %}
        <div class="blog-card__body">
          <span class="blog-tag">{{ article.tags | first | default: 'Post' }}</span>
          <h2>{{ article.title }}</h2>
          <p>{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
          <time>{{ article.published_at | date: '%B %d, %Y' }}</time>
        </div>
      </a>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="pagination">
      {{ paginate | default_pagination }}
    </div>
  {% endif %}
</div>
