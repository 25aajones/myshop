<section class="apps-section">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Ziyu Development</p>
      <h2>{{ section.settings.heading | default: 'Apps on the App Store' }}</h2>
    </div>

    <div class="apps-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection != blank %}
        {% for product in collection.products limit: section.settings.limit %}
          <a href="{{ product.url }}" class="app-card">
            <div class="app-card__icon">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: product.title }}
              {% else %}
                <div class="app-icon-placeholder">{{ product.title | slice: 0 }}</div>
              {% endif %}
            </div>
            <div class="app-card__info">
              <h3>{{ product.title }}</h3>
              <p>{{ product.metafields.custom.tagline | default: product.description | strip_html | truncate: 60 }}</p>
              <span class="app-store-badge">App Store ↗</span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          {% if block.type == 'app' %}
            <div class="app-card" {{ block.shopify_attributes }}>
              <div class="app-card__icon">
                {% if block.settings.icon %}
                  {{ block.settings.icon | image_url: width: 200 | image_tag: loading: 'lazy' }}
                {% else %}
                  <div class="app-icon-placeholder">{{ block.settings.name | slice: 0 }}</div>
                {% endif %}
              </div>
              <div class="app-card__info">
                <h3>{{ block.settings.name }}</h3>
                <p>{{ block.settings.tagline }}</p>
                {% if block.settings.app_store_url != blank %}
                  <a href="{{ block.settings.app_store_url }}" class="app-store-badge" target="_blank" rel="noopener">App Store ↗</a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_coming_soon %}
      <div class="coming-soon-strip">
        <p class="section-label">Coming Soon</p>
        <div class="coming-soon-grid">
          {% for block in section.blocks %}
            {% if block.type == 'coming_soon' %}
              <div class="coming-soon-card" {{ block.shopify_attributes }}>
                <div class="app-icon-placeholder coming-soon-icon">{{ block.settings.name | slice: 0 }}</div>
                <span>{{ block.settings.name }}</span>
                <em>Coming Soon</em>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Apps Section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Apps on the App Store" },
    { "type": "collection", "id": "collection", "label": "Apps Collection" },
    { "type": "range", "id": "limit", "label": "Max Apps", "min": 2, "max": 12, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "show_coming_soon", "label": "Show Coming Soon", "default": true }
  ],
  "blocks": [
    {
      "type": "app",
      "name": "App (manual)",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "App Icon" },
        { "type": "text", "id": "name", "label": "App Name", "default": "My App" },
        { "type": "text", "id": "tagline", "label": "Short Description", "default": "A great app." },
        { "type": "url", "id": "app_store_url", "label": "App Store URL" }
      ]
    },
    {
      "type": "coming_soon",
      "name": "Coming Soon App",
      "settings": [
        { "type": "text", "id": "name", "label": "App Name", "default": "New App" }
      ]
    }
  ],
  "presets": [
    { "name": "Apps Section" }
  ]
}
{% endschema %}
