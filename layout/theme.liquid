<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }}</title>

  {{ content_for_header }}

  <style>
    {% assign theme_mode = settings.theme_mode | default: 'dark' %}
    {% assign light_bg = settings.light_background_color | default: '#ffffff' %}
    {% assign light_text = settings.light_text_color | default: '#0a0a0a' %}
    {% assign light_surface = settings.light_surface_color | default: '#f4f4f6' %}
    {% assign light_border = settings.light_border_color | default: '#e5e7eb' %}
    {% assign light_primary = settings.light_primary_color | default: '#1f2937' %}
    {% assign light_primary_text = settings.light_primary_text_color | default: '#ffffff' %}
    {% assign light_secondary = settings.light_secondary_color | default: '#3b82f6' %}
    {% assign light_secondary_text = settings.light_secondary_text_color | default: '#ffffff' %}
    {% assign light_surface_text = settings.light_surface_text_color | default: '#1f2937' %}

    {% assign dark_bg = settings.background_color | default: '#0a0a0a' %}
    {% assign dark_text = settings.text_color | default: '#ffffff' %}
    {% assign dark_surface = settings.surface_color | default: '#111111' %}
    {% assign dark_border = settings.border_color | default: '#222222' %}
    {% assign dark_primary = settings.primary_color | default: '#ffffff' %}
    {% assign dark_primary_text = settings.primary_text_color | default: '#000000' %}
    {% assign dark_secondary = settings.secondary_color | default: '#10b981' %}
    {% assign dark_secondary_text = settings.secondary_text_color | default: '#ffffff' %}
    {% assign dark_surface_text = settings.surface_text_color | default: '#ffffff' %}

    {% if theme_mode == 'light' %}
      :root {
        color-scheme: light;
        --page-bg: {{ light_bg }};
        --page-text: {{ light_text }};
        --surface-bg: {{ light_surface }};
        --surface-text: {{ light_surface_text }};
        --border-color: {{ light_border }};
        --primary-color: {{ light_primary }};
        --primary-text: {{ light_primary_text }};
        --secondary-color: {{ light_secondary }};
        --secondary-text: {{ light_secondary_text }};
        --heading-font: {{ settings.heading_font }};
        --body-font: {{ settings.body_font }};
        --header-bg: rgba(255, 255, 255, 0.96);
      }
    {% elsif theme_mode == 'auto' %}
      :root {
        color-scheme: dark;
        --page-bg: {{ dark_bg }};
        --page-text: {{ dark_text }};
        --surface-bg: {{ dark_surface }};
        --surface-text: {{ dark_surface_text }};
        --border-color: {{ dark_border }};
        --primary-color: {{ dark_primary }};
        --primary-text: {{ dark_primary_text }};
        --secondary-color: {{ dark_secondary }};
        --secondary-text: {{ dark_secondary_text }};
        --heading-font: {{ settings.heading_font }};
        --body-font: {{ settings.body_font }};
        --header-bg: rgba(10, 10, 10, 0.92);
      }

      @media (prefers-color-scheme: light) {
        :root {
          color-scheme: light;
          --page-bg: {{ light_bg }};
          --page-text: {{ light_text }};
          --surface-bg: {{ light_surface }};
          --surface-text: {{ light_surface_text }};
          --border-color: {{ light_border }};
          --primary-color: {{ light_primary }};
          --primary-text: {{ light_primary_text }};
          --secondary-color: {{ light_secondary }};
          --secondary-text: {{ light_secondary_text }};
          --heading-font: {{ settings.heading_font }};
          --body-font: {{ settings.body_font }};
          --header-bg: rgba(255, 255, 255, 0.96);
        }
      }
    {% else %}
      :root {
        color-scheme: dark;
        --page-bg: {{ dark_bg }};
        --page-text: {{ dark_text }};
        --surface-bg: {{ dark_surface }};
        --surface-text: {{ dark_surface_text }};
        --border-color: {{ dark_border }};
        --primary-color: {{ dark_primary }};
        --primary-text: {{ dark_primary_text }};
        --secondary-color: {{ dark_secondary }};
        --secondary-text: {{ dark_secondary_text }};
        --heading-font: {{ settings.heading_font }};
        --body-font: {{ settings.body_font }};
        --header-bg: rgba(10, 10, 10, 0.92);
      }
    {% endif %}
  </style>

  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body>

{% if settings.popup_enable %}
  <div class="promo-popup" data-popup data-popup-delay="{{ settings.popup_delay | default: 3 }}" data-popup-repeat-days="{{ settings.popup_repeat_days | default: 7 }}" aria-hidden="true">
    <aside class="promo-popup-card">
      <button class="promo-popup-close" type="button" aria-label="Close promotional popup">×</button>
      <p class="eyebrow">Limited offer</p>
      <h2>{{ settings.popup_headline | default: 'Subscribe and save 15%' }}</h2>
      <p>{{ settings.popup_text | default: 'Join our mailing list for early access to launches, flash sales, and exclusive offers.' }}</p>
      <div class="button-group">
        <a href="{{ settings.popup_button_url | default: '/pages/newsletter' }}" class="btn btn-primary">
          {{ settings.popup_button_text | default: 'Join now' }}
        </a>
      </div>
    </aside>
  </div>
{% endif %}

{% if settings.announcement_message != blank %}
  <div class="announcement-bar">
    <div class="container announcement-content">
      <p>{{ settings.announcement_message }}</p>
      {% if settings.announcement_url != blank %}
        <a href="{{ settings.announcement_url }}" class="announcement-link">
          {{ settings.announcement_button_text | default: 'Shop now' }}
        </a>
      {% endif %}
    </div>
  </div>
{% endif %}

<header class="site-header">
  <div class="container nav-wrapper">
    <a href="/" class="logo">{{ settings.logo_text | default: shop.name }}</a>

    <button class="mobile-menu-toggle" aria-expanded="false" aria-controls="site-navigation">
      <span class="icon-bar"></span>
      <span class="icon-bar"></span>
      <span class="icon-bar"></span>
      <span class="sr-only">Menu</span>
    </button>

    <nav id="site-navigation" class="site-nav" data-menu>
      <a href="{{ settings.nav_url_1 | default: '/' }}">{{ settings.nav_label_1 | default: 'Home' }}</a>

      <div class="nav-dropdown" data-dropdown>
        <button class="submenu-toggle" aria-expanded="false" type="button">
          {{ settings.submenu_label | default: settings.nav_label_2 | default: 'Shop' }}
          <span class="dropdown-caret"></span>
        </button>
        <div class="submenu-panel">
          <a href="{{ settings.submenu_link_1_url | default: '/collections/all' }}">{{ settings.submenu_link_1_label | default: 'All products' }}</a>
          <a href="{{ settings.submenu_link_2_url | default: '/collections/frontpage' }}">{{ settings.submenu_link_2_label | default: 'Featured' }}</a>
          <a href="{{ settings.submenu_link_3_url | default: '/pages/about' }}">{{ settings.submenu_link_3_label | default: 'Our story' }}</a>
        </div>
      </div>

      <a href="{{ settings.nav_url_3 | default: '/blogs/news' }}">{{ settings.nav_label_3 | default: 'Blog' }}</a>
      <a href="{{ settings.nav_url_4 | default: '/pages/contact' }}">{{ settings.nav_label_4 | default: 'Contact' }}</a>
      {% if settings.nav_label_5 != blank %}
        <a href="{{ settings.nav_url_5 | default: '/pages/support' }}">{{ settings.nav_label_5 }}</a>
      {% endif %}
    </nav>
  </div>
</header>

<main>
  {{ content_for_layout }}
</main>

{% render 'footer' %}

{{ 'theme.js' | asset_url | script_tag }}

</body>
</html>